# Life OS binds only to this computer by default.
LIFE_OS_HOST=127.0.0.1
LIFE_OS_PORT=8765

# Leave empty in source control. The installer generates a random value locally.
LIFE_OS_API_KEY=
LIFE_OS_SESSION_SECRET=

# Runtime data lives outside the repository by default.
LIFE_OS_DATA_DIR=~/Library/Application Support/LifeOS

# Optional local AI integration. It remains disabled in V1.
LIFE_OS_AI_ENABLED=false
LIFE_OS_OLLAMA_URL=http://127.0.0.1:11434/api/generate
LIFE_OS_OLLAMA_MODEL=deepseek-r1:7b
LIFE_OS_OLLAMA_TIMEOUT_SECONDS=20

# Backup policy.
LIFE_OS_BACKUP_DAILY_RETENTION=30
LIFE_OS_BACKUP_MONTHLY_RETENTION=12
